# Supply-chain hardening: only ever resolve packages from the official npm
# registry (no alternate/private registries, no implicit redirects). Git,
# tarball, and other "exotic" non-registry specifiers are disallowed by policy
# and must not be added to package.json. See pnpm-workspace.yaml for the
# release-age cooldown and build-script allow-list.
registry=https://registry.npmjs.org/
